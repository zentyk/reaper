{
  "name": "reaper-vue",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "asbuild:debug": "asc assembly/index.ts --target debug",
    "asbuild:release": "asc assembly/index.ts -b pathfinder.wasm -O3 --optimizeLevel 3 --shrinkLevel 1",
    "asbuild": "npm run asbuild:debug && npm run asbuild:release",
    "start": "npx serve ."
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@primevue/themes": "^4.5.4",
    "primevue": "^4.5.4",
    "three": "^0.160.0",
    "vue": "^3.4.15"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.3",
    "assemblyscript": "^0.28.9",
    "jsdom": "^24.0.0",
    "vite": "^5.0.12",
    "vitest": "^1.2.2"
  },
  "exports": {
    ".": {
      "import": "./build/release.js",
      "types": "./build/release.d.ts"
    }
  }
}